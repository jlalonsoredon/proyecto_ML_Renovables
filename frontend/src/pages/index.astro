---
import Layout from "../layouts/Layout.astro";
import Hero from "../components/sections/hero/Hero.astro";
import KeyServices from "../components/sections/services/KeyServices.astro";
import GetInvolved from "../components/sections/cta/GetInvolved.astro";
import Container from "../components/shared/Container.astro";
import Title2 from "../components/shared/Title2.astro";
import Title3 from "../components/shared/Title3.astro";
import Paragraph from "../components/shared/Paragraph.astro";
import CtaButton from "../components/shared/CtaButton.astro";
import { currentPrediction } from "../data/mockData";

const API_BASE_URL = import.meta.env.PUBLIC_API_URL || "http://localhost:8000";
---

<Layout title="Predicción Eólica ML">
  <main class="flex flex-col gap-y-20 md:gap-y-40 overflow-hidden">
    <!-- 1. CABECERA (Hero original) -->
    <Hero />

    <!-- 2. BLOQUE "Discover Our Cutting-edge Green Energy Technologies" -->
    <!-- <KeyServices /> -->

    <!-- 3. TARJETAS DE RESULTADOS (estilo GetInvolved/Join Us) -->
    <GetInvolved />

    <!-- 4. SECCIÓN DE PREDICCIÓN ACTUAL -->
    <Container>
      <section class="py-12 text-center">
        <Title2>Predicción para Mañana</Title2>
        <div class="grid md:grid-cols-2 gap-8 items-center">
          <div>
            <Paragraph>
              Nuestro modelo predictivo utiliza datos meteorológicos de AEMET y
              datos históricos de generación de la API de Red Eléctrica de España
              para estimar la producción eólica del día siguiente.
            </Paragraph>
            <div class="mt-6">
              <a href="/resultados" class="inline-block bg-primary text-white px-6 py-3 rounded-lg hover:bg-primary-dark transition-colors">
                Ver Todos los Gráficos
              </a>
            </div>
          </div>
          <div class="bg-gradient-to-r from-blue-600 to-blue-800 rounded-xl p-8 text-white" id="prediction-card">
            <Title3 className="text-white">Producción Eólica Prevista</Title3>
            <p class="text-blue-100 text-sm mb-4" id="prediction-date">Fecha: {currentPrediction.fecha}</p>
            <div class="text-5xl font-bold" id="prediction-value">{currentPrediction.prediccionMWh.toLocaleString()}</div>
            <div class="text-blue-200 text-xl mt-2">MWh</div>
            <div class="mt-6 grid grid-cols-2 gap-4 text-sm">
              <div>
                <span class="text-blue-300">Velocidad viento:</span>
                <div class="font-semibold" id="prediction-velmedia">{currentPrediction.features.velmedia} m/s</div>
              </div>
              <div>
                <span class="text-blue-300">Ráfagas:</span>
                <div class="font-semibold" id="prediction-racha">{currentPrediction.features.racha} m/s</div>
              </div>
            </div>
            <p class="text-xs text-blue-300 mt-4" id="prediction-modelo">Modelo: {currentPrediction.modelo}</p>
            <p class="text-xs text-blue-400 mt-2" id="loading-indicator">Cargando datos en tiempo real...</p>
          </div>
        </div>
      </section>
    </Container>

    <!-- 5. SECCIÓN DE PROCESO (CTA final) -->
    <Container>
      
      <Title2>¿Quieres Saber Cómo Funciona?</Title2>
      <section class="py-12 text-center bg-gray-100 dark:bg-gray-800 rounded-xl">
        
        <Paragraph>
          Descubre el proceso completo: desde la obtención de datos de las APIs
          hasta la predicción con Machine Learning.
        </Paragraph>
        <div class="flex justify-center mt-6 gap-4">
          <CtaButton href="/proceso" variant="primary">
            Ver el Proceso
          </CtaButton>
          <CtaButton href="/resultados" variant="secondary">
            Ver Resultados
          </CtaButton>
        </div>
      </section>
    </Container>
  </main>
</Layout>

<script define:vars={{ API_BASE_URL }}>
  const API_URL = API_BASE_URL;

  async function fetchPrediction() {
    try {
      const response = await fetch(`${API_URL}/api/prediction`);
      const data = await response.json();

      document.getElementById("prediction-date").textContent = `Fecha: ${data.fecha}`;
      document.getElementById("prediction-value").textContent = Number(data.prediccionMWh).toLocaleString();
      document.getElementById("prediction-velmedia").textContent = `${data.features.velmedia} m/s`;
      document.getElementById("prediction-racha").textContent = `${data.features.racha} m/s`;
      document.getElementById("prediction-modelo").textContent = `Modelo: ${data.modelo}`;
      document.getElementById("loading-indicator").textContent = "Datos actualizados desde el servidor";
      document.getElementById("loading-indicator").classList.add("text-green-400");
    } catch (error) {
      console.error("Error fetching prediction:", error);
      document.getElementById("loading-indicator").textContent = "Usando datos locales (servidor no disponible)";
    }
  }

  fetchPrediction();
</script>