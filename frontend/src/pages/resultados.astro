---
import Layout from "../layouts/Layout.astro";
import Container from "../components/shared/Container.astro";
import Title from "../components/shared/Title.astro";
import Title2 from "../components/shared/Title2.astro";
import Title3 from "../components/shared/Title3.astro";
import Paragraph from "../components/shared/Paragraph.astro";
import ModelComparisonChart from "../components/charts/ModelComparisonChart.astro";
import PredictionChart from "../components/charts/PredictionChart.astro";
import { currentPrediction } from "../data/mockData";

const API_BASE_URL = import.meta.env.PUBLIC_API_URL || "http://localhost:8000";
---

<Layout title="Resultados - Predicción Eólica ML">
  <main class="flex flex-col gap-y-12 md:gap-y-20 overflow-hidden pb-20">
    <Container>
      <div class="py-12 text-center">
        <Title>Resultados y Predicciones</Title>
        <Paragraph>
          Visualización de datos históricos, comparación de modelos y predicciones actuales
        </Paragraph>
      </div>
    </Container>

    <Container>
      <section class="bg-gradient-to-r from-blue-600 to-blue-800 rounded-xl p-8 text-white mb-12" id="prediction-section">
        <div class="flex flex-col md:flex-row items-center justify-between gap-6">
          <div>
            <Title3>Predicción para Mañana</Title3>
            <p class="text-blue-100 text-sm mt-1" id="prediction-date">Última actualización: {currentPrediction.fecha}</p>
          </div>
          <div class="text-center">
            <div class="text-5xl font-bold" id="prediction-value">{currentPrediction.prediccionMWh.toLocaleString()}</div>
            <div class="text-blue-200">MWh</div>
          </div>
          <div class="text-right text-sm" id="prediction-features">
            <p><strong>Modelo:</strong> <span id="prediction-modelo">{currentPrediction.modelo}</span></p>
            <p><strong>Velocidad viento:</strong> <span id="prediction-velmedia">{currentPrediction.features.velmedia} m/s</span></p>
            <p><strong>Ráfagas:</strong> <span id="prediction-racha">{currentPrediction.features.racha} m/s</span></p>
          </div>
        </div>
        <p class="text-xs text-blue-400 mt-4 text-center" id="loading-indicator">Cargando datos en tiempo real...</p>
      </section>
    </Container>

    <Container>
      <section class="mb-12">
        <Title2>Predicción vs Real</Title2>
        <Paragraph>
          Comparación entre la producción real de energía eólica y las predicciones del modelo
          Linear Regression. La línea naranja discontinua muestra la predicción para mañana.
        </Paragraph>
        <div class="mt-6">
          <PredictionChart />
        </div>
      </section>
    </Container>

    <Container>
      <section class="mb-12">
        <Title2>Comparación de Modelos de Machine Learning</Title2>
        <Paragraph>
          Comparación de rendimiento entre los diferentes modelos probados. Linear Regression
          obtiene el mejor resultado general con R² = 0.579.
        </Paragraph>
        <div class="mt-6">
          <ModelComparisonChart />
        </div>
      </section>
    </Container>

  </main>
</Layout>

<script define:vars={{ API_BASE_URL }}>
  const API_URL = API_BASE_URL;

  async function fetchPrediction() {
    try {
      const response = await fetch(`${API_URL}/api/prediction`);
      const data = await response.json();

      document.getElementById("prediction-date").textContent = `Última actualización: ${data.fecha}`;
      document.getElementById("prediction-value").textContent = Number(data.prediccionMWh).toLocaleString();
      document.getElementById("prediction-modelo").textContent = data.modelo;
      document.getElementById("prediction-velmedia").textContent = `${data.features.velmedia} m/s`;
      document.getElementById("prediction-racha").textContent = `${data.features.racha} m/s`;
      document.getElementById("loading-indicator").textContent = "Datos actualizados desde el servidor";
      document.getElementById("loading-indicator").classList.add("text-green-400");
    } catch (error) {
      console.error("Error fetching prediction:", error);
      document.getElementById("loading-indicator").textContent = "Usando datos locales (servidor no disponible)";
    }
  }

  fetchPrediction();
</script>