---
const API_BASE_URL = import.meta.env.PUBLIC_API_URL || "http://localhost:8000";
---

<div class="bg-white dark:bg-gray-800 rounded-xl p-4 shadow-md">
  <div class="flex flex-wrap items-center justify-between gap-2 mb-3">
    <h3 class="text-base font-semibold text-gray-800 dark:text-white">
      Linear Regression — Último mes + pronóstico mañana
    </h3>
    <span id="pc-subtitle" class="text-xs text-gray-500 dark:text-gray-400 italic"></span>
  </div>
  <div id="pc-loading" class="text-center py-10 text-gray-400 text-sm">Cargando datos…</div>
  <div id="pc-error"   class="hidden text-center py-10 text-red-500 text-sm"></div>
  <div id="pc-wrap"    class="hidden" style="position:relative;height:340px;">
    <canvas id="predictionChart" style="width:100%;height:340px;"></canvas>
  </div>
</div>

<script is:inline src="https://cdn.jsdelivr.net/npm/chart.js@4.4.3/dist/chart.umd.min.js"></script>
<script is:inline define:vars={{ API_BASE_URL }}>
(function () {
  var API_URL = API_BASE_URL;

  function fmtDate(iso) {
    var d = new Date(iso + "T12:00:00");
    return d.getDate() + "\n" + d.toLocaleString("es-ES", { month: "short" });
  }

  function buildChart(data) {
    var n = data.fechas_hist.length;

    // Etiquetas: historial + mañana
    var labels = data.fechas_hist.map(fmtDate);
    labels.push("🔮\n" + fmtDate(data.manana.fecha));

    // Real (histórico, GWh)
    var dsReal = data.real_gwh.concat([null]);

    // Predicción LR histórica → puede tener nulls; conectamos con mañana
    var dsPredHist = data.pred_gwh.map(function(v) { return v; });
    // Añadimos el punto de mañana al final de la línea de predicción
    dsPredHist.push(data.manana.pred_gwh);

    // Punto especial mañana (solo el último índice)
    var dsManana = new Array(n).fill(null);
    dsManana.push(data.manana.pred_gwh);

    // Viento z-score (eje derecho)
    var dsVel   = data.vel_norm.concat([data.manana.vel_norm]);
    var dsRacha = data.racha_norm.concat([data.manana.racha_norm]);

    // Color de las barras de viento: más oscuro para "mañana"
    var velColors   = data.vel_norm.map(function()  { return "rgba(128,203,196,0.55)"; });
    velColors.push("rgba(38,166,154,0.85)");
    var rachaColors = data.racha_norm.map(function() { return "rgba(255,179,0,0.50)"; });
    rachaColors.push("rgba(255,143,0,0.85)");

    var ctx = document.getElementById("predictionChart");
    new Chart(ctx, {
      type: "bar",
      data: {
        labels: labels,
        datasets: [
          // ── Barras de viento (eje derecho) ───────────────────────────────
          {
            label: "velmedia (std)",
            type: "bar",
            data: dsVel,
            backgroundColor: velColors,
            yAxisID: "yWind",
            order: 3,
            barPercentage: 0.4,
            categoryPercentage: 0.5,
          },
          {
            label: "racha (std)",
            type: "bar",
            data: dsRacha,
            backgroundColor: rachaColors,
            yAxisID: "yWind",
            order: 3,
            barPercentage: 0.4,
            categoryPercentage: 0.5,
          },
          // ── Línea Real (eje izquierdo) ────────────────────────────────────
          {
            label: "Real (GWh)",
            type: "line",
            data: dsReal,
            borderColor: "#2196F3",
            backgroundColor: "rgba(33,150,243,0.08)",
            borderWidth: 2,
            pointRadius: 4,
            pointBackgroundColor: "#2196F3",
            tension: 0.3,
            fill: false,
            yAxisID: "yGen",
            order: 1,
            spanGaps: false,
          },
          // ── Línea Predicción LR histórica + mañana ────────────────────────
          {
            label: "Predicción LR (GWh)",
            type: "line",
            data: dsPredHist,
            borderColor: "#FF5722",
            borderDash: [5, 4],
            borderWidth: 1.8,
            pointRadius: 3,
            pointStyle: "rectRot",
            tension: 0.3,
            fill: false,
            yAxisID: "yGen",
            order: 1,
            spanGaps: true,
          },
          // ── Diamante de mañana ────────────────────────────────────────────
          {
            label: "Predicción mañana",
            type: "line",
            data: dsManana,
            borderColor: "#9C27B0",
            backgroundColor: "#9C27B0",
            pointRadius: 10,
            pointStyle: "rectRot",
            borderWidth: 2,
            showLine: false,
            yAxisID: "yGen",
            order: 0,
          },
        ],
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        animation: false,
        plugins: {
          legend: {
            position: "top",
            labels: { boxWidth: 12, font: { size: 11 } },
          },
          tooltip: {
            callbacks: {
              label: function(ctx) {
                var v = ctx.parsed.y;
                if (v === null) return null;
                if (ctx.dataset.yAxisID === "yWind") {
                  return ctx.dataset.label + ": " + v.toFixed(2) + " σ";
                }
                return ctx.dataset.label + ": " + v.toLocaleString("es-ES") + " GWh";
              },
            },
          },
          // Línea vertical separando historial de mañana
          annotation: null,
        },
        scales: {
          x: {
            ticks: { font: { size: 9 }, maxRotation: 0, autoSkip: true, maxTicksLimit: 15 },
            grid: { display: false },
          },
          yGen: {
            type: "linear",
            position: "left",
            title: { display: true, text: "Generación eólica (GWh)", font: { size: 10 } },
            ticks: {
              font: { size: 9 },
              callback: function(v) { return v.toLocaleString("es-ES"); },
            },
            grid: { color: "rgba(0,0,0,0.06)" },
          },
          yWind: {
            type: "linear",
            position: "right",
            title: { display: true, text: "Viento (z-score)", font: { size: 10 }, color: "#9e9e9e" },
            ticks: { font: { size: 9 }, color: "#9e9e9e" },
            grid: { drawOnChartArea: false },
          },
        },
      },
    });
  }

  function init() {
    if (typeof Chart === "undefined") { setTimeout(init, 50); return; }

    fetch(API_URL + "/api/prediction-chart")
      .then(function(r) {
        if (!r.ok) throw new Error("HTTP " + r.status);
        return r.json();
      })
      .then(function(data) {
        document.getElementById("pc-loading").style.display = "none";
        document.getElementById("pc-wrap").classList.remove("hidden");

        // Subtítulo con datos de viento de mañana
        var sub = document.getElementById("pc-subtitle");
        if (sub && data.manana) {
          sub.textContent =
            "viento AEMET: velmedia=" + data.manana.velmedia +
            " m/s  |  racha=" + data.manana.racha + " m/s";
        }

        buildChart(data);
      })
      .catch(function(err) {
        document.getElementById("pc-loading").style.display = "none";
        var el = document.getElementById("pc-error");
        el.textContent = "No se pudieron cargar los datos (" + err.message + ")";
        el.classList.remove("hidden");
      });
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", init);
  } else {
    init();
  }
})();
</script>

<script define:vars={{ API_BASE_URL }}>
  import { Chart, registerables } from "chart.js";

  Chart.register(...registerables);

  async function fetchData() {
    try {
      const [historicalRes, predictionRes] = await Promise.all([
        fetch(`${API_BASE_URL}/api/historical?days=30`),
        fetch(`${API_BASE_URL}/api/prediction`)
      ]);

      const historical = await historicalRes.json();
      const prediction = await predictionRes.json();

      document.getElementById("loading-prediction").style.display = "none";

      return {
        labels: historical.map(d => d.fecha),
        real: historical.map(d => d.eolica),
        predictionDate: prediction.fecha,
        predictionValue: prediction.prediccionMWh,
      };
    } catch (error) {
      console.error("Error fetching prediction data:", error);
      document.getElementById("loading-prediction").textContent = "Error al cargar datos";
      return null;
    }
  }

  fetchData().then(chartData => {
    if (!chartData) return;

    const ctx = document.getElementById("predictionChart");
    if (!ctx) return;

    const allLabels = [...chartData.labels, chartData.predictionDate];
    const realValues = [...chartData.real];

    const predictedValues = new Array(chartData.real.length - 1).fill(null);
    predictedValues.push(chartData.real[chartData.real.length - 1]);
    predictedValues.push(chartData.predictionValue);

    new Chart(ctx, {
      type: "line",
      data: {
        labels: allLabels,
        datasets: [
          {
            label: "Producción Real (MWh)",
            data: realValues,
            borderColor: "#2196F3",
            backgroundColor: "rgba(33, 150, 243, 0.1)",
            tension: 0.4,
            fill: false,
            pointRadius: 3,
          },
          {
            label: "Predicción (MWh)",
            data: predictedValues,
            borderColor: "#FF5722",
            backgroundColor: "rgba(255, 87, 34, 0.1)",
            borderDash: [5, 5],
            tension: 0.4,
            fill: false,
            pointRadius: 6,
            pointBackgroundColor: "#FF5722",
          },
        ],
      },
      options: {
        responsive: true,
        maintainAspectRatio: true,
        plugins: {
          legend: {
            position: "top",
          },
          tooltip: {
            callbacks: {
              label: (context) => {
                const value = context.raw;
                return value ? `${context.dataset.label}: ${Math.round(value).toLocaleString()} MWh` : "";
              },
            },
          },
        },
        scales: {
          y: {
            beginAtZero: false,
            title: {
              display: true,
              text: "MWh",
            },
          },
        },
      },
    });
  });
</script>