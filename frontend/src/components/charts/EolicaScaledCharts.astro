function corrBg(v: number): string {
  if (v >= 0) return `rgb(${Math.round(255+(239-255)*v)},${Math.round(255+(68-255)*v)},${Math.round(255+(68-255)*v)})`;
  const t = -v;
  return `rgb(${Math.round(255+(59-255)*t)},${Math.round(255+(130-255)*t)},${Math.round(255+(246-255)*t)})`;
}
