<script is:inline src="https://cdn.jsdelivr.net/npm/chart.js@4.4.3/dist/chart.umd.min.js"></script>

<div class="space-y-6 mt-4">
  <p class="text-sm text-gray-500 dark:text-gray-400 italic">
    Variables normalizadas con Standard Scaling (μ=0, σ=1). Valores positivos indican por encima de la media, negativos por debajo.
  </p>

  <!-- Scatter + Heatmap -->
  <div class="grid md:grid-cols-2 gap-6">
    <div class="bg-white dark:bg-gray-800 rounded-lg p-4 shadow">
      <h4 class="font-semibold text-sm text-gray-700 dark:text-gray-200 mb-3">
        Scatter: Velocidad Viento vs Generación Eólica (Escalados)
      </h4>
      <canvas id="scaledScatterChart" style="height:270px"></canvas>
    </div>

    <div class="bg-white dark:bg-gray-800 rounded-lg p-4 shadow">
      <h4 class="font-semibold text-sm text-gray-700 dark:text-gray-200 mb-3">
        Mapa de Calor de Correlación
      </h4>
      <div class="overflow-auto mt-4">
        <table class="w-full text-sm text-center border-collapse">
          <thead>
            <tr>
              <th class="p-2"></th>
              {CORR_LABELS.map(l => (
                <th class="p-2 text-xs text-gray-600 dark:text-gray-300 font-medium">{l}</th>
              ))}
            </tr>
          </thead>
          <tbody>
            {CORR_MATRIX.map((row, i) => (
              <tr>
                <td class="p-2 text-xs text-gray-600 dark:text-gray-300 font-medium text-right pr-3">
                  {CORR_LABELS[i]}
                </td>
                {row.map(v => (
                  <td
                    class="p-4 rounded font-bold text-base"
                    style={`background-color:${corrBg(v)};color:${Math.abs(v) > 0.5 ? '#fff' : '#374151'}`}
                  >
                    {v.toFixed(2)}
                  </td>
                ))}
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <!-- Histograma -->
  <div class="bg-white dark:bg-gray-800 rounded-lg p-4 shadow">
    <h4 class="font-semibold text-sm text-gray-700 dark:text-gray-200 mb-3">
      Distribución de Velmedia Scaled, Racha Scaled y Eólica Scaled
    </h4>
    <canvas id="scaledHistChart" style="height:280px"></canvas>
  </div>

  <!-- Series temporales -->
  <div class="bg-white dark:bg-gray-800 rounded-lg p-4 shadow">
    <h4 class="font-semibold text-sm text-gray-700 dark:text-gray-200 mb-3">
      Evolución Temporal — Serie Completa (2022–2024)
    </h4>
    <canvas id="scaledTimeFullChart" style="height:280px"></canvas>
  </div>

  <div class="grid md:grid-cols-2 gap-6">
    <div class="bg-white dark:bg-gray-800 rounded-lg p-4 shadow">
      <h4 class="font-semibold text-sm text-gray-700 dark:text-gray-200 mb-3">
        Evolución Temporal — Últimos 2 años
      </h4>
      <canvas id="scaledTime2yChart" style="height:270px"></canvas>
    </div>
    <div class="bg-white dark:bg-gray-800 rounded-lg p-4 shadow">
      <h4 class="font-semibold text-sm text-gray-700 dark:text-gray-200 mb-3">
        Evolución Temporal — Último año
      </h4>
      <canvas id="scaledTime1yChart" style="height:270px"></canvas>
    </div>
  </div>
</div>

<script is:inline define:vars={{ SCATTER_DATA, HIST_LABELS, HIST_VELMEDIA, HIST_RACHA, HIST_EOLICA, LABELS_FULL, VEL_FULL, RACHA_FULL, EOLICA_FULL, LABELS_2Y, VEL_2Y, RACHA_2Y, EOLICA_2Y, LABELS_1Y, VEL_1Y, RACHA_1Y, EOLICA_1Y }}>
(function () {
  var C_BLUE   = "#3B82F6";
  var C_ORANGE = "#F59E0B";
  var C_GREEN  = "#10B981";
  var GRID     = "rgba(156,163,175,0.2)";

  // 1. Scatter
  var ctx1 = document.getElementById("scaledScatterChart");
  if (ctx1 && !ctx1._chartInstance) {
    ctx1._chartInstance = new Chart(ctx1, {
      type: "scatter",
      data: {
        datasets: [{
          label: "velmedia_scaled vs Eólica_scaled",
          data: SCATTER_DATA,
          backgroundColor: "rgba(59,130,246,0.45)",
          borderColor: "rgba(59,130,246,0.7)",
          pointRadius: 5,
        }]
      },
      options: {
        responsive: true,
        plugins: {
          legend: { display: false },
          tooltip: { callbacks: { label: function(c) { return "(" + c.parsed.x.toFixed(2) + ", " + c.parsed.y.toFixed(2) + ")"; } } }
        },
        scales: {
          x: { title: { display: true, text: "Velocidad Media del Viento (Scaled)" }, grid: { color: GRID } },
          y: { title: { display: true, text: "Generación Eólica (Scaled)" }, grid: { color: GRID } },
        }
      }
    });
  }

  // 2. Histograma
  var ctx2 = document.getElementById("scaledHistChart");
  if (ctx2 && !ctx2._chartInstance) {
    ctx2._chartInstance = new Chart(ctx2, {
      type: "bar",
      data: {
        labels: HIST_LABELS,
        datasets: [
          { label: "Velmedia Scaled", data: HIST_VELMEDIA, backgroundColor: "rgba(59,130,246,0.55)",  borderWidth: 0 },
          { label: "Racha Scaled",    data: HIST_RACHA,    backgroundColor: "rgba(245,158,11,0.55)",  borderWidth: 0 },
          { label: "Eólica Scaled",   data: HIST_EOLICA,   backgroundColor: "rgba(16,185,129,0.55)",  borderWidth: 0 },
        ]
      },
      options: {
        responsive: true,
        plugins: { legend: { position: "top" } },
        scales: {
          x: { title: { display: true, text: "Valor Escalado" }, grid: { color: GRID } },
          y: { title: { display: true, text: "Frecuencia" }, grid: { color: GRID } },
        }
      }
    });
  }

  // 3-5. Series temporales
  function makeTimeSeries(id, labels, vel, racha, eolica) {
    var ctx = document.getElementById(id);
    if (!ctx || ctx._chartInstance) return;
    ctx._chartInstance = new Chart(ctx, {
      type: "line",
      data: {
        labels: labels,
        datasets: [
          { label: "Velmedia Scaled", data: vel,    borderColor: C_BLUE,   backgroundColor: "transparent", tension: 0.35, borderWidth: 2, pointRadius: 2 },
          { label: "Racha Scaled",    data: racha,  borderColor: C_ORANGE, backgroundColor: "transparent", tension: 0.35, borderWidth: 2, pointRadius: 2 },
          { label: "Eólica Scaled",   data: eolica, borderColor: C_GREEN,  backgroundColor: "transparent", tension: 0.35, borderWidth: 2, pointRadius: 2 },
        ]
      },
      options: {
        responsive: true,
        plugins: { legend: { position: "top" } },
        scales: {
          x: { grid: { color: GRID } },
          y: { title: { display: true, text: "Valor Escalado" }, grid: { color: GRID } },
        }
      }
    });
  }

  makeTimeSeries("scaledTimeFullChart", LABELS_FULL, VEL_FULL,  RACHA_FULL,  EOLICA_FULL);
  makeTimeSeries("scaledTime2yChart",   LABELS_2Y,   VEL_2Y,    RACHA_2Y,    EOLICA_2Y);
  makeTimeSeries("scaledTime1yChart",   LABELS_1Y,   VEL_1Y,    RACHA_1Y,    EOLICA_1Y);
})();
</script>
