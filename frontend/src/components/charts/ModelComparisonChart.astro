<div class="space-y-6">
  <p class="text-sm text-gray-500 dark:text-gray-400 italic">
    Test set: 46 semanas (jun 2025 – may 2026). Valores en GWh. Mejor modelo marcado con ⭐.
  </p>

  {MODELOS.map((m) => (
    <div class="bg-white dark:bg-gray-900 rounded-xl p-4 shadow border border-gray-100 dark:border-gray-700">
      <div class="flex flex-wrap items-center gap-x-6 gap-y-1 mb-3">
        <span class="font-semibold text-gray-800 dark:text-white text-base">{m.nombre}</span>
        <span class="text-xs bg-red-100 dark:bg-red-900/30 text-red-700 dark:text-red-300 px-2 py-0.5 rounded-full">
          RMSE: {m.rmse} k MWh
        </span>
        <span class="text-xs bg-blue-100 dark:bg-blue-900/30 text-blue-700 dark:text-blue-300 px-2 py-0.5 rounded-full">
          R²: {m.r2}
        </span>
        <span class="text-xs bg-green-100 dark:bg-green-900/30 text-green-700 dark:text-green-300 px-2 py-0.5 rounded-full">
          MAPE: {m.mape}%
        </span>
      </div>
      <div style="position:relative;height:200px;">
        <canvas id={m.id} style="width:100%;height:200px;"></canvas>
      </div>
    </div>
  ))}
</div>

<script is:inline src="https://cdn.jsdelivr.net/npm/chart.js@4.4.3/dist/chart.umd.min.js"></script>
<script is:inline define:vars={{ FECHAS, REAL, MODELOS }}>
  function makeModelChart(canvasId, predData) {
    const ctx = document.getElementById(canvasId);
    if (!ctx || ctx._mcDone) return;
    ctx._mcDone = true;

    const realGWh = REAL.map(v => +(v / 1000).toFixed(1));
    const predGWh = predData.map(v => +(v / 1000).toFixed(1));

    new Chart(ctx, {
      type: "line",
      data: {
        labels: FECHAS,
        datasets: [
          {
            label: "Real",
            data: realGWh,
            borderColor: "#111827",
            borderWidth: 1.8,
            pointRadius: 0,
            tension: 0.3,
            fill: false
          },
          {
            label: "Predicción",
            data: predGWh,
            borderColor: "tomato",
            borderWidth: 1.2,
            pointRadius: 0,
            tension: 0.3,
            fill: false
          }
        ]
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        animation: false,
        plugins: {
          legend: {
            position: "top",
            labels: { boxWidth: 12, font: { size: 11 } }
          },
          tooltip: {
            callbacks: {
              label: function(ctx) {
                return ctx.dataset.label + ": " + ctx.parsed.y.toLocaleString("es-ES") + " GWh";
              }
            }
          }
        },
        scales: {
          x: {
            ticks: { font: { size: 9 }, maxRotation: 45, autoSkip: true, maxTicksLimit: 12 },
            grid: { display: false }
          },
          y: {
            title: { display: true, text: "GWh", font: { size: 10 } },
            ticks: {
              font: { size: 9 },
              callback: function(v) { return v.toLocaleString("es-ES"); }
            },
            grid: { color: "rgba(0,0,0,0.06)" }
          }
        }
      }
    });
  }

  function initCharts() {
    if (typeof Chart === "undefined") { setTimeout(initCharts, 50); return; }
    MODELOS.forEach(function(m) { makeModelChart(m.id, m.pred); });
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initCharts);
  } else {
    initCharts();
  }
</script>