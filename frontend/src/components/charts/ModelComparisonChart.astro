---
const API_BASE_URL = import.meta.env.PUBLIC_API_URL || "http://localhost:8000";
---

<div class="bg-white dark:bg-gray-800 rounded-lg p-4 shadow-md">
  <h3 class="text-lg font-semibold mb-4 text-gray-800 dark:text-white">Comparación de Modelos ML</h3>
  <canvas id="modelComparisonChart"></canvas>
  <div id="loading-model" class="text-center py-4 text-gray-500">Cargando datos...</div>
</div>

<script define:vars={{ API_BASE_URL }}>
  import { Chart, registerables } from "chart.js";

  Chart.register(...registerables);

  async function fetchData() {
    try {
      const response = await fetch(`${API_BASE_URL}/api/model-comparison`);
      const data = await response.json();

      document.getElementById("loading-model").style.display = "none";

      return {
        labels: data.map(m => m.modelo),
        rmse: data.map(m => m.rmse),
        r2: data.map(m => m.r2 * 100000),
        mape: data.map(m => m.mape * 1000),
      };
    } catch (error) {
      console.error("Error fetching model comparison:", error);
      document.getElementById("loading-model").textContent = "Error al cargar datos";
      return null;
    }
  }

  fetchData().then(chartData => {
    if (!chartData) return;

    const ctx = document.getElementById("modelComparisonChart");
    if (!ctx) return;

    new Chart(ctx, {
      type: "bar",
      data: {
        labels: chartData.labels,
        datasets: [
          {
            label: "RMSE (MWh)",
            data: chartData.rmse,
            backgroundColor: "rgba(244, 67, 54, 0.8)",
          },
          {
            label: "R² (x100k)",
            data: chartData.r2,
            backgroundColor: "rgba(33, 150, 243, 0.8)",
          },
          {
            label: "MAPE (x1k)",
            data: chartData.mape,
            backgroundColor: "rgba(76, 175, 80, 0.8)",
          },
        ],
      },
      options: {
        responsive: true,
        maintainAspectRatio: true,
        plugins: {
          legend: {
            position: "top",
          },
        },
        scales: {
          y: {
            beginAtZero: true,
            title: {
              display: true,
              text: "Valor",
            },
          },
        },
      },
    });
  });
</script>