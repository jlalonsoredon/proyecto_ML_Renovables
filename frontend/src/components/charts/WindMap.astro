---
const PARQUES_EOLICOS = [
  { nombre: "Parque Eólico El Andévalo (Huelva)",    id: "4589X", latitud: 37.26418296737997,  longitud: -6.944856396315273  },
  { nombre: "Parque Eólico Gecama (Cuenca)",          id: "8175",  latitud: 39.40848408319995,  longitud: -2.2192737751771614 },
  { nombre: "Parque Eólico Maranchón (Guadalajara)",  id: "3013",  latitud: 41.06356588209968,  longitud: -2.206160824662825  },
  { nombre: "Parque Eólico de Borja (Zaragoza)",      id: "9299X", latitud: 41.877046928697204, longitud: -1.5630303402886618 },
  { nombre: "Parque Eólico De Tarifa",                id: "6001",  latitud: 36.037373555997895, longitud: -5.570950423574283  },
  { nombre: "Parque Eólico De Briviesca",             id: "9031C", latitud: 42.52921710077489,  longitud: -3.408352539310985  },
  { nombre: "Parque Eólico La Muela (Zaragoza)",      id: "9299X", latitud: 41.5924449830392,   longitud: -1.1575020732335635 },
];
---

<!-- Leaflet via CDN: garantiza CSS + JS correctamente -->
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
<script is:inline src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>

<div class="bg-white dark:bg-gray-800 rounded-lg p-4 shadow-md">
  <h3 class="text-lg font-semibold mb-4 text-gray-800 dark:text-white">Ubicación de Parques Eólicos</h3>
  <div id="windMap" style="height: 420px; width: 100%; border-radius: 8px;"></div>
  <div class="mt-4">
    <h4 class="text-sm font-semibold text-gray-700 dark:text-gray-300 mb-2">Parques monitorizados:</h4>
    <ul class="text-sm text-gray-600 dark:text-gray-400 space-y-1">
      {PARQUES_EOLICOS.map((p) => (
        <li>
          <span class="font-medium">{p.nombre}</span>
          <span class="ml-1 text-gray-400">(ID: {p.id})</span>
        </li>
      ))}
    </ul>
  </div>
</div>

<script is:inline define:vars={{ PARQUES_EOLICOS }}>
  // L está disponible globalmente desde el CDN
  (function () {
    const container = document.getElementById("windMap");
    if (!container || container._leaflet_id) return; // evitar doble init

    const map = L.map("windMap").setView([39.8, -3.5], 6);

    L.tileLayer("https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png", {
      attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> contributors',
      maxZoom: 18,
    }).addTo(map);

    const icon = L.divIcon({
      className: "",
      html: '<div style="background-color:#3B82F6;width:18px;height:18px;border-radius:50%;border:2.5px solid white;box-shadow:0 2px 6px rgba(0,0,0,0.4);"></div>',
      iconSize: [18, 18],
      iconAnchor: [9, 9],
    });

    PARQUES_EOLICOS.forEach(function (park) {
      L.marker([park.latitud, park.longitud], { icon })
        .addTo(map)
        .bindPopup(
          "<strong>" + park.nombre + "</strong><br>" +
          "Indicativo AEMET: " + park.id + "<br>" +
          "Lat: " + park.latitud.toFixed(5) + "<br>" +
          "Lng: " + park.longitud.toFixed(5)
        );
    });
  })();
</script>
