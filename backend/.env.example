# Environment variables for AeroPredictor Backend
# Copia este archivo como .env y configura tus valores

# API Key de AEMET (obténla en https://opendata.aemet.es/)
AEMET_API_KEY=tu_api_key_aemet

# API Key de Red Eléctrica de España (si es necesaria)
REE_API_KEY=tu_api_key_ree

# Rutas
DB_PATH=data/ree_generacion.db
MODEL_PATH=modelos/lr_eolica.joblib